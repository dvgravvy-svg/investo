rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isVerified() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'balance', 'xp', 'streak', 'lastSignIn']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.balance is number &&
             data.xp is number &&
             data.streak is number &&
             data.lastSignIn is string && data.lastSignIn.size() <= 100;
    }

    function isValidTrade(data) {
      return data.keys().hasAll(['uid', 'symbol', 'type', 'entryPrice', 'amount', 'status', 'timestamp']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.symbol is string && data.symbol.size() <= 20 &&
             data.type in ['buy', 'sell'] &&
             data.entryPrice is number &&
             data.amount is number &&
             data.status in ['open', 'closed'] &&
             (data.timestamp is timestamp || (data.timestamp is string && data.timestamp.size() <= 100));
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['uid', 'role', 'text', 'timestamp']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.role in ['user', 'ai'] &&
             data.text is string && data.text.size() <= 2000 &&
             (data.timestamp is timestamp || (data.timestamp is string && data.timestamp.size() <= 100));
    }

    // --- Match Groups ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId;
      
      allow update: if isOwner(userId) && isValidUser(incoming()) && incoming().uid == userId && (
        // Action: Daily Reward / Streak
        (incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'lastRewardClaimedAt', 'streak'])) ||
        // Action: Lesson Progression
        (incoming().diff(existing()).affectedKeys().hasOnly(['completedLessons', 'xp'])) ||
        // Action: Simulator Transactions
        (incoming().diff(existing()).affectedKeys().hasOnly(['balance'])) ||
        // Action: Profile Customization
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'petType', 'botType', 'level'])) ||
        // Action: Activity Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['lastSignIn', 'streakStartDate']))
      );

      match /trades/{tradeId} {
        allow list, get: if isOwner(userId);
        
        allow create: if isOwner(userId) && isValidId(tradeId) && isValidTrade(incoming()) && incoming().uid == userId;
        
        allow update: if isOwner(userId) && isValidTrade(incoming()) && incoming().uid == userId && (
          // Action: Close Position
          (existing().status == 'open' && incoming().status == 'closed' && 
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'exitPrice', 'profit', 'exitTime'])) ||
          // Action: Risk Management
          (existing().status == 'open' && 
           incoming().diff(existing()).affectedKeys().hasOnly(['takeProfit', 'stopLoss']))
        );
      }

      match /chat/{messageId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChatMessage(incoming()) && incoming().uid == userId;
        allow delete: if isOwner(userId);
      }
    }
  }
}
